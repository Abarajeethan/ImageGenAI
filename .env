# ── ImageGen Local — Environment ─────────────────────────────────────────────

ENVIRONMENT=development

# ── Database (SQLite — file created automatically) ────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./imagegen.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=local-dev-secret-key-change-me-32chars!!
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Default login credentials (created on first startup)
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=admin123
DEV_EDITOR_EMAIL=editor@example.com
DEV_EDITOR_PASSWORD=editor123

# ── Storage (local folder) ────────────────────────────────────────────────────
STORAGE_MODE=local
LOCAL_IMAGE_DIR=./local-images

# ── AI Mode ───────────────────────────────────────────────────────────────────
# mock  = generate placeholder images (no credentials needed)
#gemini = service-account.json
AI_MODE=mock

# ── Google Gemini (only needed when AI_MODE=gemini) ───────────────────────────
# Place your service-account.json in the backend/ folder, then set:
# GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
# GOOGLE_PROJECT_ID=your-gcp-project-id

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
PRODUCT_LOCK_TTL_SECONDS=600
